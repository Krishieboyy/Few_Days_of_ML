# Copy this file to ".env" and fill in real values for local dev.
# On Vercel/Render, add these same keys under the project's Environment Variables.

# Supabase: Project Settings -> API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Shared passcode that unlocks the app (UI gate only — see note in DEPLOY.md).
# Leave blank to disable the gate entirely (e.g. for local dev).
VITE_APP_PASSCODE=choose-a-passcode
